<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:snowflake="http://www.liquibase.org/xml/ns/snowflake"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                   http://www.liquibase.org/xml/ns/snowflake
                   http://www.liquibase.org/xml/ns/snowflake/liquibase-snowflake-latest.xsd">

    <!-- Test DATABASE IF NOT EXISTS -->
    <changeSet id="test-database-if-not-exists" author="test">
        <createDatabase databaseName="test_database_if_not_exists"
                       ifNotExists="true"
                       comment="Test IF NOT EXISTS database"/>
    </changeSet>

    <!-- Test SCHEMA IF NOT EXISTS -->
    <changeSet id="test-schema-if-not-exists" author="test">
        <createSchema schemaName="test_schema_if_not_exists"
                     ifNotExists="true"
                     comment="Test IF NOT EXISTS schema"/>
    </changeSet>

    <!-- Test SEQUENCE with all new features -->
    <changeSet id="test-sequence-complete" author="test">
        <createSequence sequenceName="test_sequence_complete"
                       startValue="1"
                       incrementBy="1"
                       order="true"
                       ifNotExists="true"
                       comment="Test complete sequence features"/>
    </changeSet>

</databaseChangeLog>