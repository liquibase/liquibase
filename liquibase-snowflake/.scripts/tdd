#!/bin/bash

# TDD Workflow - Groovy Implementation Wrapper
# Provides same interface as bash version but uses Groovy backend

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GROOVY_SCRIPT="$SCRIPT_DIR/tdd_workflow.groovy"

# Check if groovy is available
if ! command -v groovy &> /dev/null; then
    echo "❌ Groovy not found. Please install Groovy:"
    echo "   brew install groovy  # macOS"
    echo "   sdk install groovy   # SDKMAN"
    exit 1
fi

# Execute groovy script with all arguments
groovy "$GROOVY_SCRIPT" "$@"