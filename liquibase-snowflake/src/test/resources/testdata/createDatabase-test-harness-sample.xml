<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:snowflake="http://www.liquibase.org/xml/ns/snowflake"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                      http://www.liquibase.org/xml/ns/snowflake
                      http://www.liquibase.org/xml/ns/snowflake/liquibase-snowflake-latest.xsd">

    <!-- Include the standard test harness initialization -->
    <include file="liquibase/harness/change/changelogs/snowflake/common/init.xml"/>

    <!-- Clean up any existing test databases -->
    <changeSet id="cleanup-test-databases" author="test-harness" runAlways="true">
        <preConditions onFail="CONTINUE">
            <sqlCheck expectedResult="1">SELECT 1</sqlCheck>
        </preConditions>
        <sql>
            DROP DATABASE IF EXISTS LBTEST_BASIC_DB;
            DROP DATABASE IF EXISTS LBTEST_TRANSIENT_DB;
            DROP DATABASE IF EXISTS LBTEST_RETENTION_DB;
            DROP DATABASE IF EXISTS LBTEST_REPLACE_DB;
            DROP DATABASE IF EXISTS LBTEST_CLONE_SOURCE_DB;
            DROP DATABASE IF EXISTS LBTEST_CLONED_DB;
            DROP DATABASE IF EXISTS LBTEST_CONDITIONAL_DB;
        </sql>
    </changeSet>

    <!-- Test 1: Basic database creation -->
    <changeSet id="test-1-basic-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_BASIC_DB"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_BASIC_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 2: Transient database (no retention) -->
    <changeSet id="test-2-transient-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_TRANSIENT_DB"
                                  transient="true"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_TRANSIENT_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 3: Database with retention settings and comment -->
    <changeSet id="test-3-retention-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_RETENTION_DB"
                                  dataRetentionTimeInDays="7"
                                  maxDataExtensionTimeInDays="30"
                                  comment="Test database with retention settings"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_RETENTION_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 4: OR REPLACE database -->
    <changeSet id="test-4a-create-initial" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_REPLACE_DB"
                                  comment="Initial database"/>
    </changeSet>
    
    <changeSet id="test-4b-replace-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_REPLACE_DB"
                                  orReplace="true"
                                  comment="Replaced database"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_REPLACE_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 5: IF NOT EXISTS database -->
    <changeSet id="test-5a-create-conditional" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_CONDITIONAL_DB"
                                  comment="Initial conditional database"/>
    </changeSet>
    
    <changeSet id="test-5b-conditional-create" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_CONDITIONAL_DB"
                                  ifNotExists="true"
                                  comment="Should not replace existing"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_CONDITIONAL_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 6: Clone database -->
    <changeSet id="test-6a-create-source" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_CLONE_SOURCE_DB"
                                  comment="Source database for cloning"/>
        <sql>
            -- Add some content to clone
            CREATE SCHEMA LBTEST_CLONE_SOURCE_DB.TEST_SCHEMA;
            CREATE TABLE LBTEST_CLONE_SOURCE_DB.TEST_SCHEMA.TEST_TABLE (ID INT);
        </sql>
    </changeSet>
    
    <changeSet id="test-6b-clone-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_CLONED_DB"
                                  cloneFrom="LBTEST_CLONE_SOURCE_DB"
                                  comment="Cloned database"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_CLONED_DB</sql>
        </rollback>
    </changeSet>

    <!-- Test 7: Database with collation -->
    <changeSet id="test-7-collation-database" author="test-harness">
        <snowflake:createDatabase databaseName="LBTEST_COLLATION_DB"
                                  defaultDdlCollation="en-ci"
                                  comment="Database with custom collation"/>
        <rollback>
            <sql>DROP DATABASE IF EXISTS LBTEST_COLLATION_DB</sql>
        </rollback>
    </changeSet>

    <!-- Final cleanup -->
    <changeSet id="final-cleanup" author="test-harness" runAlways="true">
        <sql>
            DROP DATABASE IF EXISTS LBTEST_BASIC_DB;
            DROP DATABASE IF EXISTS LBTEST_TRANSIENT_DB;
            DROP DATABASE IF EXISTS LBTEST_RETENTION_DB;
            DROP DATABASE IF EXISTS LBTEST_REPLACE_DB;
            DROP DATABASE IF EXISTS LBTEST_CLONE_SOURCE_DB;
            DROP DATABASE IF EXISTS LBTEST_CLONED_DB;
            DROP DATABASE IF EXISTS LBTEST_CONDITIONAL_DB;
            DROP DATABASE IF EXISTS LBTEST_COLLATION_DB;
        </sql>
    </changeSet>

    <!-- Include the standard test harness cleanup -->
    <include file="liquibase/harness/change/changelogs/snowflake/common/cleanup.xml"/>

</databaseChangeLog>